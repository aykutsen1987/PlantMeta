# ============================================================
# PlantMeta Backend — Environment Variables
# Bu dosyayı .env olarak kopyalayın ve değerleri doldurun.
# .env dosyasını asla git'e push etmeyin!
# ============================================================

# Uygulamanın Android tarafına vereceğiniz API anahtarı
# Rastgele güçlü bir string belirleyin (örn: openssl rand -hex 32)
PLANT_API_KEY=buraya_guclu_bir_anahtar_yazin

# OpenAI API Anahtarı (https://platform.openai.com/api-keys)
OPENAI_API_KEY=sk-...

# Kullanılacak OpenAI modeli
OPENAI_MODEL=gpt-4o

# Sunucu portu (Render.com bu değeri otomatik belirler)
PORT=3000

# Ortam (development | production)
NODE_ENV=development
