# ─────────────────────────────────────────────────────────────
# PlantMeta Backend — Ortam Değişkenleri
# Bu dosyayı .env olarak kopyalayın ve değerleri doldurun:
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────

# Groq API Key — https://console.groq.com/keys adresinden alın (ücretsiz)
GROQ_API_KEY=gsk_buraya_groq_api_keyinizi_yazin

# Groq model seçimi (vision destekli modeller):
#   meta-llama/llama-4-scout-17b-16e-instruct   ← önerilen (hızlı + ücretsiz)
#   meta-llama/llama-4-maverick-17b-128e-instruct ← daha güçlü
GROQ_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# Android uygulamasının isteklerini doğrulamak için API anahtarı
# İstediğiniz rastgele bir string girebilirsiniz
PLANT_API_KEY=buraya_android_app_icin_api_key_yazin

# Sunucu portu (Render.com otomatik ayarlar)
PORT=3000
